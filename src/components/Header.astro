---
import Logo from './Logo.astro';
import {
  useTranslations,
  otherLocale,
  htmlLang,
  type Locale,
} from '../i18n/ui';

interface Props {
  locale: Locale;
  /** 'home' = section links (default); 'article' = a single "back" link. */
  variant?: 'home' | 'article';
}
const { locale, variant = 'home' } = Astro.props;
const t = useTranslations(locale);
const other = otherLocale(locale);
const fr = locale === 'fr-fr';

// Language switch link: same page, other locale.
const segments = Astro.url.pathname.split('/').filter(Boolean);
segments.shift(); // remove the current locale
const barePath = segments.length ? `/${segments.join('/')}` : '/';
const switchHref = `/${other}${barePath === '/' ? '/' : barePath}`;

const home = `/${locale}/`;
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href={home} aria-label="Nicolas Fiascaro — accueil">
      <Logo size={30} class="site-header__mark" />
      <span class="site-header__name">Nicolas&nbsp;Fiascaro</span>
    </a>

    <nav class="site-header__nav" aria-label={locale === 'fr-fr' ? 'Navigation principale' : 'Primary navigation'}>
      {
        variant === 'article' ? (
          <a class="site-header__back" href={`/${locale}/#work`}>
            {fr ? '← Projets' : '← Work'}
          </a>
        ) : (
          /* Section links: hidden in descent mode (desktop) where the nav moves
             onto the altimeter; kept for static / mobile mode. */
          <span class="site-header__links">
            <a href="#work">{t('nav.work')}</a>
            <a href="#about">{t('nav.about')}</a>
            <a href="#contact">{t('nav.contact')}</a>
          </span>
        )
      }
      <button
        class="site-header__theme"
        type="button"
        data-theme-toggle
        aria-label={locale === 'fr-fr' ? 'Basculer le thème clair/sombre' : 'Toggle light/dark theme'}
        aria-pressed="false"
      >
        <svg class="site-header__theme-icon" width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
          <circle cx="9" cy="9" r="7.5" fill="none" stroke="currentColor" stroke-width="1.5" />
          <path d="M9 1.5 A7.5 7.5 0 0 1 9 16.5 Z" fill="currentColor" />
        </svg>
      </button>
      <a
        class="site-header__lang mono-label"
        href={switchHref}
        hreflang={htmlLang[other]}
        lang={htmlLang[other]}
      >
        {t('lang.switch')}
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: var(--z-nav);
    color: var(--ink);
    transition: color var(--dur-base) var(--ease-out-quart);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
    padding-block: var(--space-s);
  }
  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    text-decoration: none;
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
  }
  .site-header__mark {
    flex: none;
  }
  .site-header__nav {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 0.4rem + 2vw, 2.25rem);
    font-weight: var(--weight-medium);
  }
  /* display: contents -> the 3 links inherit the nav gap. */
  .site-header__links {
    display: contents;
  }
  /* In descent mode (desktop), the section nav lives on the altimeter. */
  :global(body.is-dolly) .site-header__links {
    display: none;
  }
  .site-header__nav a {
    text-decoration: none;
  }
  .site-header__nav a:not(.site-header__lang):hover {
    text-decoration: underline;
  }
  .site-header__lang {
    padding: 0.35em 0.85em;
    border: 1px solid currentColor;
    border-radius: var(--radius-pill);
    opacity: 0.85;
  }
  .site-header__lang:hover {
    opacity: 1;
  }
  /* Theme toggle: half-circle (echoing the site's "porthole / circle" motif). */
  .site-header__theme {
    display: inline-flex;
    color: inherit;
    opacity: 0.8;
    transition: opacity var(--dur-fast) var(--ease-out-quart);
  }
  .site-header__theme:hover {
    opacity: 1;
  }
  .site-header__theme-icon {
    display: block;
    transition: transform var(--dur-base) var(--ease-out-expo);
  }
  :global(html[data-theme='dark']) .site-header__theme-icon {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .site-header__theme-icon {
      transition: none;
    }
  }

  @media (max-width: 40rem) {
    .site-header__name {
      display: none;
    }
    .site-header__nav {
      gap: var(--space-s);
      font-size: var(--step--1);
    }
  }
</style>

<script>
  // Light/dark theme toggle. The initial theme is already set before
  // paint by BaseLayout's inline script (localStorage > prefers-color-scheme).
  // Here we only handle the click + persistence + the theme-color meta.
  const KEY = 'nf-theme';
  const root = document.documentElement;
  const btn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  const meta = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
  const PAGE = { light: '#f6f3ed', dark: '#211f1c' };

  const sync = (theme: string) => {
    btn?.setAttribute('aria-pressed', String(theme === 'dark'));
    if (meta) meta.setAttribute('content', theme === 'dark' ? PAGE.dark : PAGE.light);
  };

  sync(root.dataset.theme === 'dark' ? 'dark' : 'light');

  btn?.addEventListener('click', () => {
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    try {
      localStorage.setItem(KEY, next);
    } catch {}
    sync(next);
  });
</script>
