---
import Section from '../Section.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { useTranslations, type Locale } from '../../i18n/ui';
import { projects } from '../../data/projects';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

// Pull the hero image from each project's case study (same locale) to back the
// index with a full-bleed, cursor-tilted image. Projects without a hero yet
// simply show the neutral tinted backdrop when hovered.
const studies = await getCollection('caseStudies', (e) => e.data.locale === locale);
const heroById = new Map(studies.map((s) => [s.data.project, s.data.hero]));

const items = projects.map((p, i) => ({
  ...p,
  num: String(i + 1).padStart(2, '0'),
  hero: heroById.get(p.id),
}));
const previews = items.filter((p) => p.hero);
---

<Section tone="light" id="work" labelledby="work-title">
  {/* Full-bleed image backdrop, tilted by the cursor. Sits inside the section
      (so it scales with the descent) but breaks out of the reading column. */}
  <div class="work__bg" aria-hidden="true">
    {
      previews.map((p) => (
        <Image
          class="work__bg-img"
          data-project={p.id}
          src={p.hero!}
          alt=""
          widths={[720, 1200]}
          sizes="100vw"
          format="webp"
          quality={58}
          loading="lazy"
          decoding="async"
        />
      ))
    }
  </div>

  <header class="work__head">
    <h2 id="work-title" class="mono-label">{t('work.title')}</h2>
  </header>

  <ul class="work__list" role="list">
    {
      items.map((p) => (
        <li class="project">
          <a
            class="project__link"
            href={`/${locale}/projects/${p.slug[locale]}/`}
            data-project={p.id}
          >
            <span class="project__num mono-label">{p.num}</span>
            <span class="project__title">{p.title[locale]}</span>
            <span class="project__meta">
              <span class="project__client">{p.client}</span>
              <span class="project__year mono-label">{p.year}</span>
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</Section>

<style>
  /* --- Cursor-tilted image backdrop --- */
  .work__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    opacity: 0;
    transition: opacity var(--dur-slow, 0.45s) var(--ease-out-quart);
    transform: perspective(1400px) rotateX(var(--rx, 0deg)) rotateY(var(--ry, 0deg))
      scale(1.08) translate3d(var(--px, 0px), var(--py, 0px), 0);
    transform-origin: center;
    will-change: transform;
  }
  .work__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    filter: grayscale(1);
    transition:
      opacity var(--dur-slow, 0.45s) var(--ease-out-quart),
      filter var(--dur-slow, 0.45s) var(--ease-out-quart);
  }
  /* Ambient at rest; full presence + a hint of colour on hover. */
  .work__bg-img.is-active {
    opacity: 0.5;
  }
  .work__bg.is-hovering .work__bg-img.is-active {
    opacity: 1;
    filter: grayscale(0.35);
  }
  /* Scrim: keeps the titles readable, weighted toward the left column, and
     tints the image toward the theme so it reads in light and dark. */
  .work__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        color-mix(in oklch, var(--page) 84%, transparent),
        color-mix(in oklch, var(--page) 48%, transparent) 68%
      ),
      color-mix(in oklch, var(--page) 28%, transparent);
  }
  /* No hover target or reduced motion → never show the backdrop. */
  @media (hover: none), (prefers-reduced-motion: reduce) {
    .work__bg {
      display: none;
    }
  }

  /* --- Index list (above the backdrop) --- */
  .work__head,
  .work__list {
    position: relative;
    z-index: 1;
  }
  .work__head {
    margin-bottom: var(--space-l);
  }
  .work__list {
    margin: 0;
  }
  .project {
    border-block-start: 1px solid var(--hairline);
  }
  .project:last-child {
    border-block-end: 1px solid var(--hairline);
  }
  .project__link {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: baseline;
    gap: var(--space-m);
    padding-block: var(--space-m);
    text-decoration: none;
    color: var(--ink);
    transition: opacity var(--dur-base) var(--ease-out-quart);
  }
  .project__num {
    color: var(--ink-muted);
  }
  .project__title {
    font-size: var(--step-3);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
    transition: transform var(--dur-base) var(--ease-out-quart);
  }
  .project__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    gap: var(--space-3xs);
    white-space: nowrap;
  }
  .project__client {
    font-weight: var(--weight-medium);
  }
  .project__year {
    color: var(--ink-muted);
  }

  /* Editorial focus: dim the siblings when hovering the list. */
  @media (hover: hover) and (pointer: fine) {
    .work__list:hover .project {
      opacity: 0.4;
    }
    .work__list:hover .project:hover {
      opacity: 1;
    }
    .project__link:hover .project__title {
      transform: translateX(0.5rem);
    }
  }

  @media (max-width: 52rem) {
    .project__link {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        'num title'
        'num meta';
      column-gap: var(--space-s);
      row-gap: var(--space-2xs);
      align-items: start;
    }
    .project__num {
      grid-area: num;
    }
    .project__title {
      grid-area: title;
      font-size: var(--step-2);
    }
    .project__meta {
      grid-area: meta;
      flex-direction: row;
      align-items: baseline;
      gap: var(--space-2xs);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .project__link:hover .project__title {
      transform: none;
    }
  }
</style>

<script>
  // Full-bleed backdrop that tilts with the cursor and crossfades to the
  // hovered project. Desktop pointer + motion only; armed by the descent via
  // `data-settled` (pointer-events on the list are gated there too).
  const section = document.getElementById('work');
  const bg = section?.querySelector<HTMLElement>('.work__bg');
  const list = section?.querySelector<HTMLElement>('.work__list');
  const fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  const motionOk = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Pre-decode the backdrops while idle so arriving at the Projects station
  // never stalls the frame on first image decode.
  if (bg && motionOk) {
    const idle = window.requestIdleCallback ?? ((cb: () => void) => window.setTimeout(cb, 1200));
    idle(() => {
      for (const el of bg.querySelectorAll('img')) el.decode?.().catch(() => {});
    });
  }

  if (section && bg && list && fine && motionOk) {
    const imgs = new Map<string, HTMLElement>();
    for (const el of bg.querySelectorAll<HTMLElement>('[data-project]')) {
      const id = el.getAttribute('data-project');
      if (id) imgs.set(id, el);
    }
    // Ambient backdrop at rest = the first project that has an image.
    const first = bg.querySelector<HTMLElement>('.work__bg-img');
    const firstId = first?.getAttribute('data-project') ?? null;
    let activeImg: HTMLElement | null = first ?? null;
    activeImg?.classList.add('is-active');

    const setActive = (id: string | null) => {
      const el = id ? (imgs.get(id) ?? null) : null;
      if (el === activeImg) return;
      activeImg?.classList.remove('is-active');
      activeImg = el;
      activeImg?.classList.add('is-active');
    };

    const MAX_ROT = 4; // deg
    const MAX_SHIFT = 12; // px
    let tRx = 0;
    let tRy = 0;
    let tPx = 0;
    let tPy = 0;
    let rx = 0;
    let ry = 0;
    let px = 0;
    let py = 0;
    let raf = 0;

    const loop = () => {
      rx += (tRx - rx) * 0.08;
      ry += (tRy - ry) * 0.08;
      px += (tPx - px) * 0.08;
      py += (tPy - py) * 0.08;
      bg.style.setProperty('--rx', rx.toFixed(3) + 'deg');
      bg.style.setProperty('--ry', ry.toFixed(3) + 'deg');
      bg.style.setProperty('--px', px.toFixed(2) + 'px');
      bg.style.setProperty('--py', py.toFixed(2) + 'px');
      if (Math.abs(tRx - rx) + Math.abs(tRy - ry) + Math.abs(tPx - px) + Math.abs(tPy - py) > 0.01) {
        raf = requestAnimationFrame(loop);
      } else {
        raf = 0;
      }
    };
    const kick = () => {
      if (!raf) raf = requestAnimationFrame(loop);
    };

    section.addEventListener('pointermove', (e) => {
      const nx = (e.clientX / window.innerWidth - 0.5) * 2;
      const ny = (e.clientY / window.innerHeight - 0.5) * 2;
      tRy = nx * MAX_ROT;
      tRx = -ny * MAX_ROT;
      tPx = nx * MAX_SHIFT;
      tPy = ny * MAX_SHIFT;
      kick();
    });

    for (const row of list.querySelectorAll<HTMLElement>('.project__link')) {
      row.addEventListener('pointerenter', () => {
        bg.classList.add('is-hovering');
        setActive(row.getAttribute('data-project'));
      });
    }

    const rest = () => {
      bg.classList.remove('is-hovering');
      setActive(firstId);
      tRx = tRy = tPx = tPy = 0;
      kick();
    };
    section.addEventListener('pointerleave', rest);

    // The station's list pointer-events are gated on `data-settled`; if it flies
    // away mid-hover no pointerleave fires, so reset off the attribute too.
    new MutationObserver(() => {
      if (!section.hasAttribute('data-settled')) rest();
    }).observe(section, { attributes: true, attributeFilter: ['data-settled'] });
  }
</script>
