---
import { Image } from 'astro:assets';
import Button from '../Button.astro';
import Logo from '../Logo.astro';
import { useTranslations, type Locale } from '../../i18n/ui';
import disc from '../../assets/aerial-disc.png';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const fr = locale === 'fr';
const cvHref =
  locale === 'fr' ? '/cv/nicolas-fiascaro-fr.pdf' : '/cv/nicolas-fiascaro-en.pdf';
const alt = fr
  ? 'Vue aérienne du sol : Nicolas Fiascaro, longue ombre projetée sur un sol terracotta.'
  : 'Aerial view of the ground: Nicolas Fiascaro, long shadow cast on a terracotta floor.';
---

<section
  id="contact"
  class="landing"
  aria-labelledby="contact-title"
>
  <div class="landing__media">
    <Image
      class="landing__photo"
      src={disc}
      alt={alt}
      widths={[900, 1400, 2000]}
      sizes="100vw"
      format="webp"
      quality={78}
      loading="lazy"
    />
  </div>
  <div class="landing__scrim" aria-hidden="true"></div>

  <div class="container landing__content">
    <Logo size={54} class="landing__mark" title="Nicolas Fiascaro" />
    <p class="landing__kicker mono-label">{t('contact.location')}</p>
    <h2 id="contact-title" class="landing__title">Nicolas&nbsp;Fiascaro</h2>
    <p class="landing__lead">{t('contact.lead')}</p>

    <ul class="landing__links" role="list">
      <li>
        <a href="https://www.linkedin.com/in/nicolas-fiascaro/" rel="me noopener" target="_blank">LinkedIn</a>
      </li>
      <li>
        <a href="https://github.com/Cocola" rel="me noopener" target="_blank">GitHub</a>
      </li>
    </ul>

    <div class="landing__actions">
      <Button href={cvHref} variant="secondary" download>{t('hero.cv')}</Button>
    </div>

    <p class="landing__credit">© 2026 Nicolas Fiascaro</p>
  </div>
</section>

<style>
  /* The landing, B&W: the disc (lit ground, in grayscale) settles on the
     charcoal — a bright porthole in the dark. The light text rests on a
     charcoal scrim at the bottom (the shadow on the ground) for contrast. */
  .landing {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    color: var(--ink);
    background-color: var(--page);
  }
  .landing__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .landing__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.06);
  }
  /* Vignette in the theme tint OVER the photo: the edges fade
     EXACTLY into --page (same color), whatever the theme or the
     photo's brightness -> no band/rectangle, a soft "spotlight"
     centered on the subject. */
  .landing__media::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse 50% 48% at 50% 48%,
      transparent 44%,
      var(--page) 100%
    );
  }
  /* Dark = "night" landing: darkened photo so the light ink
     stays legible. The --page (charcoal) vignette fades the edges. */
  :global(html[data-theme='dark']) .landing__photo {
    filter: grayscale(1) contrast(1.04) brightness(0.62);
  }
  /* Bottom scrim in the theme tint: protects text legibility in static
     mode (reduced-motion / mobile), invisible on a solid background. */
  .landing__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      var(--page) 0%,
      color-mix(in oklch, var(--page) 55%, transparent) 26%,
      transparent 58%
    );
  }
  .landing__content {
    position: relative;
    z-index: 2;
    padding-block: var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    align-items: start;
  }
  .landing__mark {
    color: var(--ink);
    margin-bottom: var(--space-m);
  }
  .landing__kicker {
    color: var(--ink-muted);
    margin-bottom: var(--space-2xs);
  }
  .landing__title {
    font-size: var(--step-5);
    font-weight: var(--weight-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-tight);
  }
  .landing__lead {
    font-size: var(--step-1);
    color: var(--ink-muted);
  }
  .landing__links {
    display: flex;
    gap: var(--space-m);
    margin: var(--space-2xs) 0 0;
    font-size: var(--step-1);
  }
  .landing__links a {
    text-decoration: none;
    border-block-end: 1px solid currentColor;
    padding-block-end: 0.1em;
    transition: opacity var(--dur-fast) var(--ease-out-quart);
  }
  .landing__links a:hover {
    color: var(--accent);
  }
  .landing__actions {
    margin-top: var(--space-s);
  }
  .landing__credit {
    margin-top: var(--space-l);
    font-size: var(--step--1);
    color: var(--ink-muted);
    opacity: 0.7;
  }

  /* Phones: the narrow viewport pushes the text block up to mid-screen,
     onto the photo's bright ground where the muted kicker drowns (light
     mode). Raise the scrim so the whole block sits on a --page wash. */
  @media (max-width: 40rem) {
    .landing__scrim {
      background: linear-gradient(
        to top,
        var(--page) 0%,
        color-mix(in oklch, var(--page) 78%, transparent) 38%,
        color-mix(in oklch, var(--page) 40%, transparent) 62%,
        transparent 85%
      );
    }
  }
</style>

<script>
  // Static flow (mobile / reduced-motion): once the landing fills most of the
  // viewport it becomes the site's closing cover — the header slides away
  // (body.is-landing, styled in Header.astro). Skipped in dolly mode, where
  // sections live in a pinned, GSAP-transformed stage and ratios are
  // meaningless there.
  const landing = document.getElementById('contact');
  if (landing && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      ([entry]) => {
        const dolly = document.body.classList.contains('is-dolly');
        document.body.classList.toggle(
          'is-landing',
          !dolly && entry.intersectionRatio >= 0.55,
        );
      },
      { threshold: [0, 0.55] },
    );
    io.observe(landing);
  }
</script>
