---
import Section from '../Section.astro';
import { useTranslations, type Locale } from '../../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const fr = locale === 'fr';
---

<Section tone="light" full class="hero" labelledby="hero-title">
  <p class="hero__role mono-label">{t('hero.role')}</p>

  <h1 id="hero-title" class="hero__title">
    {
      fr ? (
        <>
          Je <em>conçois</em> et <em>développe</em> la couche produit,
          <span class="hero__dim"> du design system à l’interface.</span>
        </>
      ) : (
        <>
          I <em>design</em> and <em>build</em> the product layer,
          <span class="hero__dim"> from design system to interface.</span>
        </>
      )
    }
  </h1>

  <a class="hero__scroll" href="#skills">
    <span class="sr-only">{fr ? 'Descendre à la section suivante' : 'Scroll to the next section'}</span>
    <svg class="hero__scroll-arrow" width="20" height="38" viewBox="0 0 20 38" fill="none" aria-hidden="true">
      <path d="M10 2 V31" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      <path d="M3 24 L10 32 L17 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
</Section>

<style>
  .hero :global(.section__inner) {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }
  .hero__role {
    color: var(--ink-muted);
  }
  .hero__title {
    max-width: 18ch;
    font-size: var(--step-5);
    font-weight: var(--weight-display);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display);
  }
  /* Antiqua: emphasis by one weight step (no italic, no caps) */
  .hero__title em {
    font-style: normal;
    font-weight: var(--weight-semibold);
  }
  .hero__dim {
    color: var(--ink-muted);
    font-weight: var(--weight-regular);
  }
  /* Scroll cue: an invitation to descend (coherent with the free-fall
     concept), a real anchor to the next section. */
  .hero__scroll {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 44px;
    block-size: 44px;
    margin-top: var(--space-l);
    color: var(--ink-muted);
    transition: color var(--dur-fast) var(--ease-out-quart);
  }
  .hero__scroll:hover {
    color: var(--ink);
  }
  .hero__scroll-arrow {
    display: block;
    animation: hero-bob 1.9s var(--ease-in-out, ease-in-out) infinite;
  }
  @keyframes hero-bob {
    0%,
    100% {
      transform: translateY(-3px);
    }
    50% {
      transform: translateY(3px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-arrow {
      animation: none;
    }
  }
</style>
