---
interface Props {
  /** Path under /public, e.g. "/videos/demo.mp4". */
  src: string;
  /** Intrinsic pixel dimensions — reserve the box to avoid layout shift. */
  width: number;
  height: number;
  caption?: string;
  /** Break out wider than the reading column, up to the masthead width. */
  wide?: boolean;
}
const { src, width, height, caption, wide = false } = Astro.props;

// A still first-frame poster keeps the box from rendering as a blank rectangle
// before the clip enters view and autoplays. Generated under /videos/posters/.
const poster = src
  .replace('/videos/', '/videos/posters/')
  .replace(/\.mp4$/, '.jpg');
---

<figure class:list={['case-video', { 'case-video--wide': wide }]}>
  <video
    class="case-video__el"
    src={src}
    poster={poster}
    width={width}
    height={height}
    style={`aspect-ratio: ${width} / ${height};`}
    loop
    muted
    playsinline
    preload="metadata"
    controls
    aria-label={caption}
    data-showcase></video>
  {caption && <figcaption class="case-video__caption">{caption}</figcaption>}
</figure>

<style>
  .case-video {
    margin-block: var(--space-xl);
  }
  /* Break out of the centered reading column to a wider, page-centered band. */
  .case-video--wide {
    width: min(64rem, 92vw);
    margin-inline-start: 50%;
    transform: translateX(-50%);
  }
  .case-video__el {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-m);
    border: 1px solid var(--hairline);
    background: var(--surface, #0e0e0e);
    /* Same media language as the case covers: grayscale at rest, colour on
       play (poster grays too, so the reveal reads as intentional). */
    filter: grayscale(1);
    transition: filter var(--dur-slow) var(--ease-out-quart);
  }
  .case-video__el.is-playing {
    filter: grayscale(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .case-video__el {
      transition: none;
    }
  }
  .case-video__caption {
    margin-top: var(--space-2xs);
    font-size: var(--step--1);
    color: var(--ink-muted);
    text-wrap: pretty;
  }
</style>

<script>
  // Progressive enhancement: silent showcase clips autoplay-loop while in view
  // (and pause out of view). Under reduced motion we leave the native controls
  // so nothing moves until the user chooses to play.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const clips = document.querySelectorAll<HTMLVideoElement>('video[data-showcase]');

  // Colour <-> grayscale follows the actual playing state (works for both the
  // autoplay path and a manual play under reduced motion).
  for (const v of clips) {
    v.addEventListener('play', () => v.classList.add('is-playing'));
    v.addEventListener('pause', () => v.classList.remove('is-playing'));
  }

  if (!reduce && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          const v = e.target as HTMLVideoElement;
          if (e.isIntersecting) void v.play().catch(() => {});
          else v.pause();
        }
      },
      { threshold: 0.25 },
    );
    for (const v of clips) {
      v.removeAttribute('controls');
      io.observe(v);
    }
  }
</script>
