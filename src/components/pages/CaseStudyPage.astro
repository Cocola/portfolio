---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../Header.astro';
import Footer from '../Footer.astro';
import { localizedPath, useTranslations, type Locale } from '../../i18n/ui';
import { projects } from '../../data/projects';

interface Props {
  locale: Locale;
  id: string;
}
const { locale, id } = Astro.props;
const t = useTranslations(locale);
const fr = locale === 'fr';
const lang = locale;

const project = projects.find((p) => p.id === id)!;

const studies = await getCollection(
  'caseStudies',
  (e) => e.data.project === id && e.data.locale === locale,
);
const study = studies[0];
const Content = study ? (await render(study)).Content : null;

// Adjacent projects for the prev/next pager (wraps around). There is no
// separate "all projects" index page — navigation stays project-to-project.
const idx = projects.findIndex((p) => p.id === id);
const prev = projects[(idx - 1 + projects.length) % projects.length];
const next = projects[(idx + 1) % projects.length];

const disciplines = project.tags.map((tag) =>
  tag === 'design' ? 'Design' : fr ? 'Développement' : 'Engineering',
);

const title = `${project.title[lang]} — Nicolas Fiascaro`;
const description = study?.data.lead ?? project.summary[lang];

// The slug differs per locale, so each locale's bare path must be built from
// the project data (not by naive path prefixing) for correct hreflang + switch.
const other = locale === 'fr' ? 'en' : 'fr';
const alternatePaths = {
  fr: `/projects/${project.slug.fr}/`,
  en: `/projects/${project.slug.en}/`,
};
const switchPath = `/projects/${project.slug[other]}/`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: project.title[lang],
    headline: project.title[lang],
    abstract: description,
    inLanguage: fr ? 'fr-FR' : 'en-US',
    dateCreated: project.year,
    creator: { '@type': 'Person', name: 'Nicolas Fiascaro' },
    about: project.client,
  },
];
---

<BaseLayout {title} {description} locale={lang} {jsonLd} {alternatePaths}>
  <Header slot="header" locale={lang} variant="article" {switchPath} />

  <article class="case">
    <header class="case__hero container">
      <div class="case__topline">
        <p class="case__eyebrow mono-label">{project.client} · {project.year}</p>
        <nav
          class="case__pager"
          aria-label={fr ? 'Navigation entre projets' : 'Project navigation'}
        >
          <a
            class="case__pager-link mono-label"
            href={localizedPath(locale, `/projects/${prev.slug[locale]}/`)}
            title={prev.title[lang]}
          >
            ← {fr ? 'Précédent' : 'Previous'}
          </a>
          <span class="case__pager-sep" aria-hidden="true">/</span>
          <a
            class="case__pager-link mono-label"
            href={localizedPath(locale, `/projects/${next.slug[locale]}/`)}
            title={next.title[lang]}
          >
            {fr ? 'Suivant' : 'Next'} →
          </a>
        </nav>
      </div>
      <h1 class="case__title">
        {project.title[lang]}
      </h1>
      {study && <p class="case__lead">{study.data.lead}</p>}

      <dl class="case__meta">
        {
          study && (
            <div class="case__meta-item">
              <dt class="mono-label">{fr ? 'Rôle' : 'Role'}</dt>
              <dd>{study.data.role}</dd>
            </div>
          )
        }
        {
          study && (
            <div class="case__meta-item">
              <dt class="mono-label">{fr ? 'Période' : 'Period'}</dt>
              <dd>{study.data.period}</dd>
            </div>
          )
        }
        <div class="case__meta-item">
          <dt class="mono-label">{fr ? 'Discipline' : 'Discipline'}</dt>
          <dd>{disciplines.join(' · ')}</dd>
        </div>
        {
          study && study.data.stack.length > 0 && (
            <div class="case__meta-item case__meta-item--wide">
              <dt class="mono-label">Stack</dt>
              <dd>{study.data.stack.join(' · ')}</dd>
            </div>
          )
        }
      </dl>
    </header>

    {
      study?.data.hero && (
        <figure class="case__cover container">
          <Image
            class="case__cover-img"
            src={study.data.hero}
            alt={study.data.heroAlt ?? project.title[lang]}
            widths={[900, 1400, 2000]}
            sizes="(max-width: 78rem) 92vw, 78rem"
            format="webp"
            quality={80}
          />
        </figure>
      )
    }

    <div class="case__body container">
      {
        Content ? (
          <div class="prose">
            <Content />
          </div>
        ) : (
          <p class="case__soon">
            {fr
              ? 'L’étude de cas détaillée arrive bientôt.'
              : 'The detailed case study is coming soon.'}
          </p>
        )
      }
    </div>

    <nav
      class="case__foot container"
      aria-label={fr ? 'Projet précédent et suivant' : 'Previous and next project'}
    >
      <a class="case__foot-link case__foot-link--prev" href={localizedPath(locale, `/projects/${prev.slug[locale]}/`)}>
        <span class="case__foot-dir mono-label">← {fr ? 'Précédent' : 'Previous'}</span>
        <span class="case__foot-title">{prev.title[lang]}</span>
      </a>
      <a class="case__foot-link case__foot-link--next" href={localizedPath(locale, `/projects/${next.slug[locale]}/`)}>
        <span class="case__foot-dir mono-label">{fr ? 'Suivant' : 'Next'} →</span>
        <span class="case__foot-title">{next.title[lang]}</span>
      </a>
    </nav>
  </article>

  <Footer slot="footer" locale={lang} />
</BaseLayout>

<style>
  .case {
    padding-block-start: calc(var(--space-3xl) + var(--space-l));
    padding-block-end: var(--space-3xl);
  }

  /* Eyebrow (left) + minimal prev/next (right) on one line. */
  .case__topline {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-s) var(--space-m);
    margin-bottom: var(--space-s);
  }
  .case__pager {
    display: flex;
    gap: var(--space-s);
    align-items: baseline;
  }
  .case__pager-link {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out-quart);
  }
  .case__pager-link:hover {
    color: var(--ink);
  }
  .case__pager-sep {
    color: var(--ink-muted);
    opacity: 0.5;
  }

  /* Header (eyebrow, title, meta) is wide and left-aligned; only the long-form
     body is capped and centered on the page. */
  .case__eyebrow {
    color: var(--ink-muted);
  }
  .case__title {
    font-size: var(--step-5);
  }
  .case__lead {
    margin-top: var(--space-m);
    font-size: var(--step-2);
    color: var(--ink-muted);
    max-width: var(--measure);
    text-wrap: pretty;
  }
  .case__meta {
    margin-top: var(--space-2xl);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: var(--space-l) var(--space-xl);
    padding-block: var(--space-l);
    border-block: 1px solid var(--hairline);
  }
  .case__meta-item--wide {
    grid-column: 1 / -1;
  }
  .case__meta dt {
    color: var(--ink-muted);
    margin-bottom: var(--space-3xs);
  }
  .case__meta dd {
    margin: 0;
    font-size: var(--step-0);
  }

  /* Optional full-width cover image (only rendered when `hero` is set). */
  .case__cover {
    margin-top: var(--space-2xl);
  }
  .case__cover-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-l);
    border: 1px solid var(--hairline);
    filter: grayscale(1);
    transition: filter var(--dur-slow, 0.45s) var(--ease-out-quart);
  }
  /* Colour in when hovered (desktop) or scrolled into the active zone. */
  .case__cover:hover .case__cover-img,
  .case__cover.is-active .case__cover-img {
    filter: grayscale(0);
  }

  .case__body {
    margin-top: var(--space-2xl);
  }
  .case__soon {
    color: var(--ink-muted);
  }

  /* Long-form MDX output. */
  .prose {
    max-width: var(--container-text);
    margin-inline: auto;
  }
  .prose :global(h2) {
    font-size: var(--step-2);
    margin-block: var(--space-xl) var(--space-s);
    text-wrap: balance;
  }
  .prose :global(h3) {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-block: var(--space-l) var(--space-2xs);
  }
  .prose :global(p) {
    margin-block: var(--space-s);
    line-height: var(--leading-normal);
  }
  .prose :global(strong) {
    font-weight: var(--weight-semibold);
  }
  .prose :global(blockquote) {
    margin: var(--space-l) 0;
    padding-inline-start: var(--space-m);
    border-inline-start: 2px solid var(--hairline);
    color: var(--ink-muted);
    font-style: normal;
  }

  /* Bottom project-to-project navigation. */
  .case__foot {
    margin-top: var(--space-3xl);
    padding-top: var(--space-l);
    border-top: 1px solid var(--hairline);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-l) var(--space-xl);
  }
  .case__foot-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    text-decoration: none;
    color: var(--ink);
  }
  .case__foot-link--next {
    align-items: flex-end;
    text-align: right;
  }
  .case__foot-dir {
    color: var(--ink-muted);
    transition: color var(--dur-fast) var(--ease-out-quart);
  }
  .case__foot-title {
    font-size: var(--step-1);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
    max-width: 26ch;
  }
  .case__foot-link:hover .case__foot-dir {
    color: var(--ink);
  }

  @media (max-width: 40rem) {
    .case__foot {
      grid-template-columns: 1fr;
    }
    .case__foot-link--next {
      align-items: flex-start;
      text-align: start;
    }
  }
</style>

<script>
  // Colour the hero once it's substantially in view (scroll trigger), the
  // touch-friendly counterpart to the hover colourisation.
  const cover = document.querySelector('.case__cover');
  if (cover && 'IntersectionObserver' in window) {
    // Trigger when the cover overlaps the central band of the viewport. Using a
    // negative rootMargin (not intersectionRatio) works even when the hero is
    // taller than the viewport, where the ratio could never reach a threshold.
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) cover.classList.toggle('is-active', e.isIntersecting);
      },
      { rootMargin: '-30% 0px -30% 0px', threshold: 0 },
    );
    io.observe(cover);
  }
</script>
