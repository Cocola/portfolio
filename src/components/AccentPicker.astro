---
import { type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const fr = locale === 'fr';

// Curated accents. `key` drives the [data-accent] token override in tokens.css
// (bordeaux = default, no attribute). `swatch` is the dot colour shown in the
// picker (a mid, saturated take that reads in both themes).
const accents = [
  { key: 'bordeaux', label: fr ? 'Bordeaux' : 'Bordeaux', swatch: 'oklch(0.5 0.15 25)' },
  { key: 'emeraude', label: fr ? 'Émeraude' : 'Emerald', swatch: 'oklch(0.52 0.12 162)' },
  { key: 'ambre', label: fr ? 'Ambre' : 'Amber', swatch: 'oklch(0.7 0.13 80)' },
  { key: 'cobalt', label: fr ? 'Cobalt' : 'Cobalt', swatch: 'oklch(0.52 0.16 255)' },
];
const label = fr ? 'Couleur d’accent' : 'Accent colour';
---

<div class="accent" data-accent-picker data-open="false">
  <button
    class="accent__toggle"
    type="button"
    aria-haspopup="true"
    aria-expanded="false"
    aria-label={label}
    title={label}
  >
    <span class="accent__dot accent__dot--current" aria-hidden="true"></span>
  </button>

  <div class="accent__menu" role="menu" aria-label={label}>
    {
      accents.map((a) => (
        <button
          class="accent__opt"
          type="button"
          role="menuitemradio"
          aria-checked={a.key === 'bordeaux' ? 'true' : 'false'}
          data-accent-value={a.key}
          title={a.label}
          aria-label={a.label}
          style={`--sw:${a.swatch}`}
        >
          <span class="accent__dot" aria-hidden="true" />
        </button>
      ))
    }
  </div>
</div>

<style>
  /* Collapsed footprint = one dot; the pill expands horizontally over it. */
  .accent {
    position: relative;
    display: inline-flex;
    inline-size: 22px;
    block-size: 22px;
  }
  .accent__toggle,
  .accent__opt {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    color: inherit;
    cursor: pointer;
  }

  /* Collapsed trigger: the current accent as a single clean dot (no border). */
  .accent__toggle {
    position: absolute;
    inset: 0;
    transition:
      opacity var(--dur-fast) var(--ease-out-quart),
      transform var(--dur-fast) var(--ease-out-quart);
  }
  .accent__toggle:hover {
    transform: scale(1.1);
  }
  .accent[data-open='true'] .accent__toggle {
    opacity: 0;
    transform: scale(0.6);
    pointer-events: none;
  }

  .accent__dot {
    inline-size: 16px;
    block-size: 16px;
    border-radius: var(--radius-pill);
    background: var(--sw, var(--accent));
  }
  .accent__dot--current {
    background: var(--accent);
  }

  /* Pill: expands in place over the toggle, growing rightward. */
  .accent__menu {
    position: absolute;
    inset-block-start: 50%;
    inset-inline-start: -5px;
    z-index: 3;
    display: flex;
    gap: 7px;
    padding: 5px;
    background: var(--surface);
    border-radius: var(--radius-pill);
    box-shadow: 0 10px 30px -14px color-mix(in oklch, var(--ink) 50%, transparent);
    /* closed */
    opacity: 0;
    visibility: hidden;
    transform: translateY(-50%) scale(0.82);
    transform-origin: left center;
    transition:
      opacity var(--dur-base) var(--ease-out-quart),
      transform var(--dur-base) var(--ease-out-expo),
      visibility 0s linear var(--dur-base);
  }
  .accent[data-open='true'] .accent__menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(-50%) scale(1);
    transition:
      opacity var(--dur-base) var(--ease-out-quart),
      transform var(--dur-base) var(--ease-out-expo),
      visibility 0s;
  }

  .accent__opt {
    inline-size: 20px;
    block-size: 20px;
    border-radius: var(--radius-pill);
    /* staggered entrance */
    opacity: 0;
    transform: scale(0.3);
    transition:
      opacity var(--dur-base) var(--ease-out-quart),
      transform var(--dur-base) var(--ease-out-expo);
  }
  .accent__opt .accent__dot {
    transition: transform var(--dur-fast) var(--ease-out-quart);
  }
  .accent[data-open='true'] .accent__opt {
    opacity: 1;
    transform: none;
  }
  /* Reveal left -> right so the pill reads as growing out of the toggle. */
  .accent[data-open='true'] .accent__opt:nth-child(1) {
    transition-delay: 0.02s;
  }
  .accent[data-open='true'] .accent__opt:nth-child(2) {
    transition-delay: 0.05s;
  }
  .accent[data-open='true'] .accent__opt:nth-child(3) {
    transition-delay: 0.08s;
  }
  .accent[data-open='true'] .accent__opt:nth-child(4) {
    transition-delay: 0.11s;
  }

  .accent__opt:hover .accent__dot {
    transform: scale(1.14);
  }
  /* Selected: bigger + a halo in the dot's OWN colour (no grey border). */
  .accent__opt[aria-checked='true'] .accent__dot {
    transform: scale(1.16);
    box-shadow:
      0 0 0 2px var(--surface),
      0 0 0 3.5px var(--sw);
  }

  @media (prefers-reduced-motion: reduce) {
    .accent__toggle,
    .accent__menu,
    .accent__opt,
    .accent__dot {
      transition-duration: 0.01ms !important;
      transition-delay: 0s !important;
    }
  }
</style>

<script>
  const KEY = 'nf-accent';
  const root = document.documentElement;
  const picker = document.querySelector<HTMLElement>('[data-accent-picker]');
  if (picker) {
    const toggle = picker.querySelector<HTMLButtonElement>('.accent__toggle')!;
    const opts = Array.from(
      picker.querySelectorAll<HTMLButtonElement>('[data-accent-value]'),
    );

    const isOpen = () => picker.dataset.open === 'true';
    const setOpen = (open: boolean) => {
      picker.dataset.open = String(open);
      toggle.setAttribute('aria-expanded', String(open));
    };

    const markChecked = (value: string) => {
      for (const o of opts) {
        o.setAttribute('aria-checked', String(o.dataset.accentValue === value));
      }
    };

    const apply = (value: string, persist: boolean) => {
      // Bordeaux is the default: no attribute needed.
      if (value === 'bordeaux') root.removeAttribute('data-accent');
      else root.dataset.accent = value;
      markChecked(value);
      if (persist) {
        try {
          localStorage.setItem(KEY, value);
        } catch {}
      }
    };

    // Reflect the persisted choice (already applied pre-paint by BaseLayout).
    let current = 'bordeaux';
    try {
      current = localStorage.getItem(KEY) || 'bordeaux';
    } catch {}
    markChecked(current);

    toggle.addEventListener('click', () => setOpen(!isOpen()));
    for (const o of opts) {
      o.addEventListener('click', () => {
        apply(o.dataset.accentValue!, true);
        setOpen(false);
      });
    }

    // Dismiss on outside click / Escape.
    document.addEventListener('click', (e) => {
      if (!picker.contains(e.target as Node)) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  }
</script>
