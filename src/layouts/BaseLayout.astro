---
import '../styles/global.css';
import {
  locales,
  htmlLang,
  ogLocale,
  defaultLocale,
  localizedPath,
  stripLocale,
  useTranslations,
  type Locale,
} from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  /** OG image, absolute or relative to the site. */
  ogImage?: string;
  /** Additional JSON-LD (schema.org objects) to inject. */
  jsonLd?: Record<string, unknown>[];
  /** Disables indexing (utility pages). */
  noindex?: boolean;
  /**
   * Per-locale bare paths (without locale prefix) for the hreflang alternates.
   * Needed when the slug differs across locales (e.g. case studies). Defaults
   * to the current path for every locale.
   */
  alternatePaths?: Partial<Record<Locale, string>>;
}

const {
  title,
  description,
  locale,
  ogImage = '/og/default.png',
  jsonLd = [],
  noindex = false,
  alternatePaths,
} = Astro.props;

const t = useTranslations(locale);
const site = Astro.site ?? new URL('https://www.nicolas-fiascaro.com');

// Page path without the locale prefix -> used for the hreflang alternates.
const barePath = stripLocale(Astro.url.pathname);
const pathFor = (loc: Locale) => alternatePaths?.[loc] ?? barePath;

const canonical = new URL(localizedPath(locale, pathFor(locale)), site).href;
const alternates = locales.map((loc) => ({
  locale: loc,
  hreflang: htmlLang[loc],
  href: new URL(localizedPath(loc, pathFor(loc)), site).href,
}));
const ogImageUrl = new URL(ogImage, site).href;

const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Nicolas Fiascaro',
  jobTitle: 'Design Engineer',
  url: site.href,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Biarritz',
    addressCountry: 'FR',
  },
  sameAs: [
    'https://www.linkedin.com/in/nicolas-fiascaro/',
    'https://github.com/Cocola',
  ],
};
const schemas = [person, ...jsonLd];
---

<!doctype html>
<html lang={htmlLang[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Theme set BEFORE paint (no flash): persistent choice, otherwise OS. */}
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('nf-theme');
          const theme =
            stored ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light');
          document.documentElement.dataset.theme = theme;
          // Accent choice (bordeaux = default, no attribute).
          const accent = localStorage.getItem('nf-accent');
          if (accent && accent !== 'bordeaux')
            document.documentElement.dataset.accent = accent;
        } catch (_) {
          document.documentElement.dataset.theme = 'light';
        }
        // The descent always replays from the top: no position restoration
        // on refresh (otherwise we'd reappear in the middle of the scroll).
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    {/* Fontshare equivalents (to be replaced by self-hosted PP Editorial New +
        ABC Diatype in polish): Sentient (display antiqua) + Switzer
        (neutral grotesque body/UI). */}
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=sentient@300,400,500&f[]=switzer@400,500,600&display=swap"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonical} />
    {
      alternates.map((a) => (
        <link rel="alternate" hreflang={a.hreflang} href={a.href} />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={alternates.find((a) => a.locale === defaultLocale)?.href}
    />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nicolas Fiascaro" />
    <meta property="og:locale" content={ogLocale[locale]} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* Updated dynamically by the theme toggle (default: light). */}
    <meta name="theme-color" content="#f6f3ed" />

    {
      schemas.map((schema) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(schema)}
        />
      ))
    }
  </head>
  <body>
    <div class="atmosphere" aria-hidden="true"></div>
    <a class="skip-link" href="#main">{t('nav.skipToContent')}</a>
    <slot name="header" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
