---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { locales, useTranslations, type Locale } from '../../../i18n/ui';
import { projects } from '../../../data/projects';

export function getStaticPaths() {
  return locales.flatMap((lang) =>
    projects.map((p) => ({
      params: { lang, slug: p.slug[lang] },
      props: { id: p.id },
    })),
  );
}

const { lang } = Astro.params as { lang: Locale };
const { id } = Astro.props as { id: string };
const t = useTranslations(lang);
const fr = lang === 'fr-fr';

const project = projects.find((p) => p.id === id)!;

const studies = await getCollection(
  'caseStudies',
  (e) => e.data.project === id && e.data.locale === lang,
);
const study = studies[0];
const Content = study ? (await render(study)).Content : null;

// Next project in the index (wraps around) for the footer nav.
const idx = projects.findIndex((p) => p.id === id);
const next = projects[(idx + 1) % projects.length];

const disciplines = project.tags.map((tag) =>
  tag === 'design' ? 'Design' : fr ? 'Développement' : 'Engineering',
);

const title = `${project.title[lang]} — Nicolas Fiascaro`;
const description = study?.data.lead ?? project.summary[lang];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: project.title[lang],
    headline: project.title[lang],
    abstract: description,
    inLanguage: fr ? 'fr-FR' : 'en-US',
    dateCreated: project.year,
    creator: { '@type': 'Person', name: 'Nicolas Fiascaro' },
    about: project.client,
  },
];
---

<BaseLayout {title} {description} locale={lang} {jsonLd}>
  <Header slot="header" locale={lang} variant="article" />

  <article class="case">
    <header class="case__hero container">
      <p class="case__eyebrow mono-label">{project.client} · {project.year}</p>
      <h1 class="case__title">{project.title[lang]}</h1>
      {study && <p class="case__lead">{study.data.lead}</p>}

      <dl class="case__meta">
        {
          study && (
            <div class="case__meta-item">
              <dt class="mono-label">{fr ? 'Rôle' : 'Role'}</dt>
              <dd>{study.data.role}</dd>
            </div>
          )
        }
        {
          study && (
            <div class="case__meta-item">
              <dt class="mono-label">{fr ? 'Période' : 'Period'}</dt>
              <dd>{study.data.period}</dd>
            </div>
          )
        }
        <div class="case__meta-item">
          <dt class="mono-label">{fr ? 'Discipline' : 'Discipline'}</dt>
          <dd>{disciplines.join(' · ')}</dd>
        </div>
        {
          study && study.data.stack.length > 0 && (
            <div class="case__meta-item case__meta-item--wide">
              <dt class="mono-label">Stack</dt>
              <dd>{study.data.stack.join(' · ')}</dd>
            </div>
          )
        }
      </dl>
    </header>

    <div class="case__body container">
      {
        Content ? (
          <div class="prose">
            <Content />
          </div>
        ) : (
          <p class="case__soon">
            {fr
              ? 'L’étude de cas détaillée arrive bientôt.'
              : 'The detailed case study is coming soon.'}
          </p>
        )
      }
    </div>

    <nav class="case__more container" aria-label={fr ? 'Autres projets' : 'More work'}>
      <a class="case__next" href={`/${lang}/projects/${next.slug[lang]}/`}>
        <span class="case__next-label mono-label">{fr ? 'Projet suivant' : 'Next project'}</span>
        <span class="case__next-title">{next.title[lang]}</span>
      </a>
      <a class="case__back-all" href={`/${lang}/#work`}>{fr ? 'Tous les projets' : 'All work'} →</a>
    </nav>
  </article>

  <Footer slot="footer" locale={lang} />
</BaseLayout>

<style>
  .case {
    padding-block-start: calc(var(--space-3xl) + var(--space-l));
    padding-block-end: var(--space-3xl);
  }
  /* The article spans the full container (the title and any full-width media
     use all of it); the reading text and meta are capped narrower and
     left-aligned to the same edge. */
  .case__eyebrow {
    color: var(--ink-muted);
    margin-bottom: var(--space-s);
  }
  .case__title {
    font-size: var(--step-5);
  }
  /* Header (eyebrow, title, lead, meta) is wide and left-aligned; only the
     long-form body is capped and centered on the page. */
  .case__lead {
    margin-top: var(--space-m);
    font-size: var(--step-2);
    color: var(--ink-muted);
    max-width: var(--measure);
    text-wrap: pretty;
  }
  .case__meta {
    margin-top: var(--space-2xl);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: var(--space-l) var(--space-xl);
    padding-block: var(--space-l);
    border-block: 1px solid var(--hairline);
  }
  .case__meta-item--wide {
    grid-column: 1 / -1;
  }
  .case__meta dt {
    color: var(--ink-muted);
    margin-bottom: var(--space-3xs);
  }
  .case__meta dd {
    margin: 0;
    font-size: var(--step-0);
  }

  .case__body {
    margin-top: var(--space-2xl);
  }
  .case__soon {
    color: var(--ink-muted);
  }

  /* Long-form MDX output. */
  .prose {
    max-width: var(--container-text);
    margin-inline: auto;
  }
  .prose :global(h2) {
    font-size: var(--step-2);
    margin-block: var(--space-xl) var(--space-s);
    text-wrap: balance;
  }
  .prose :global(h3) {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-block: var(--space-l) var(--space-2xs);
  }
  .prose :global(p) {
    margin-block: var(--space-s);
    line-height: var(--leading-normal);
  }
  .prose :global(strong) {
    font-weight: var(--weight-semibold);
  }
  .prose :global(blockquote) {
    margin: var(--space-l) 0;
    padding-inline-start: var(--space-m);
    border-inline-start: 2px solid var(--hairline);
    color: var(--ink-muted);
    font-style: normal;
  }

  .case__more {
    margin-top: var(--space-3xl);
    padding-top: var(--space-l);
    border-top: 1px solid var(--hairline);
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-m);
  }
  .case__next {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    text-decoration: none;
  }
  .case__next-label {
    color: var(--ink-muted);
  }
  .case__next-title {
    font-family: var(--font-display);
    font-size: var(--step-2);
    letter-spacing: var(--tracking-display);
    transition: transform var(--dur-base) var(--ease-out-quart);
  }
  .case__next:hover .case__next-title {
    transform: translateX(0.4rem);
  }
  .case__back-all {
    text-decoration: none;
    color: var(--ink-muted);
    border-block-end: 1px solid currentColor;
    padding-block-end: 0.1em;
  }
  .case__back-all:hover {
    color: var(--ink);
  }

  @media (prefers-reduced-motion: reduce) {
    .case__next:hover .case__next-title {
      transform: none;
    }
  }
</style>
